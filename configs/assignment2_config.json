    "switch_loss_weight": 0.6,
    "switch_boundary_radius_frames": 6,
    "language_smoothing_frames": 7,
    "english_enter_threshold": 0.44,
    "english_exit_threshold": 0.38,
    "minimum_english_frames": 3,
    "switch_probability_threshold": 0.55,
    "switch_min_separation_frames": 6,
    "chunk_seconds": 5.0
  },
  "decoding": {
    "backend": "auto",
    "language": "hi",
    "task": "transcribe",
    "ngram_order": 3,
    "beam_size": 8,
    "lm_weight": 0.8,
    "length_penalty": 0.15,
    "term_bonus": 1.5,
    "initial_token_bias": 0.25,
    "max_new_tokens": 256,
    "chunk_seconds": 30.0,
    "chunk_overlap_seconds": 0.0
  },
  "speaker": {
    "embedding_dim": 256,
    "mfcc_dim": 40
