{
  "paths": {
    "original_audio": "final_original_hinglish_input.wav",
    "student_voice_audio": "User_LR_audio.wav",
    "task2_corpus": "mapping/task2_unified_hinglish_ipa_gujarati_corpus.tsv",
    "syllabus_text": "data/syllabus_text.txt",
    "lid_manifest": "data/manifests/lid_segments_template.csv",
    "spoof_manifest": "data/manifests/spoof_manifest_template.csv",
    "spoof_eval_manifest": "data/manifests/spoof_segment_eval.csv",
    "outputs_dir": "outputs",
    "lid_checkpoint": "models/lid_frame_model.pt",
    "speaker_checkpoint": "models/xvector_encoder.pt",
    "stt_model_name": "collabora/whisper-base-hindi",
    "tts_model_name": "facebook/mms-tts-guj",
    "translation_output": "outputs/translation_gujarati.txt",
    "transcript_output": "outputs/transcript_constrained.txt",
    "report_metrics_output": "outputs/report_metrics.json",
    "transcript_eval_segments": "data/manifests/transcript_eval_segments.csv"
  },
  "audio": {
    "sample_rate": 16000,
    "n_fft": 512,
    "win_length": 400,
