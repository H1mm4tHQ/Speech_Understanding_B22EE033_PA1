    "batch_size": 8,
    "epochs": 15,
    "learning_rate": 0.0003,
    "n_lfcc": 40
  },
  "adversarial": {
    "epsilon_grid": [
      0.0005,
      0.001,
      0.002,
      0.004,
      0.008
    ],
    "snr_threshold_db": 40.0,
    "target_label": 1,
    "source_label": 0,
    "segment_seconds": 5.0,
    "stride_seconds": 2.5,
    "max_candidate_segments": 8,
    "attack_steps": 10,
    "success_ratio_threshold": 0.5
  },
  "reporting": {
    "mcd_prefix_seconds": 30.0,
    "spoof_chunk_seconds": 2.0,
    "spoof_group_chunks": 2,
    "spoof_max_chunks_per_label": 28
  }
